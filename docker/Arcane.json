{
  "name": "Arcane",
  "repo": "ghcr.io/getarcaneapp/arcane:latest",
  "registry": null,
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "shell",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "cpu_set": null,
  "web_ui_url": "http://[IP]:[PORT:3552]",
  "icon": "https://getarcane.app/img/favicon.ico",
  "category": ["System"],
  "project": null,
  "support": null,
  "description": "Modern Docker management, designed for everyone. https://getarcane.app/",
  "donate": null,
  "requires": null,
  "paths": [
    {
      "name": "AppData",
      "host": "/mnt/cache/appdata/arcane",
      "container": "/app/data",
      "description": "Arcane data directory",
      "required": true
    },
    {
      "name": "Docker Socket",
      "host": "/var/run/docker.sock",
      "container": "/var/run/docker.sock",
      "description": "Docker socket for Arcane to manage containers",
      "required": true
    },
    {
      "name": "Projects",
      "host": "/mnt/cache/appdata/projects",
      "container": "/app/data/projects",
      "description": "[OPTIONAL] Directory containing your compose projects (host path must match inside container)",
      "required": false
    }
  ],
"ports": [
    {
      "name": "WebUI Port",
      "host": "3552",
      "container": "3552",
      "protocol": "TCP",
      "description": "WebUI Port",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    }
  ],
  "variables": [
    {
      "name": "ENCRYPTION_KEY",
      "key": "ENCRYPTION_KEY",
      "value": "",
      "description": "To make encryption keys on linux, [openssl rand -base64 32]",
      "required": true,
      "mask": true,
      "display": "always",
      "default": null
    },
    {
      "name": "JWT_SECRET",
      "key": "JWT_SECRET",
      "value": "",
      "description": "To make encryption keys on linux, [openssl rand -base64 32]",
      "required": true,
      "mask": true,
      "display": "always",
      "default": null
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "UTC",
      "description": "Timezone",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "APP_URL",
      "key": "APP_URL",
      "value": "http://localhost:3552",
      "description": "",
      "required": true,
      "mask": true,
      "display": "always",
      "default": null
    },
    {
      "name": "PUID",
      "key": "PUID",
      "value": "1000",
      "description": "",
      "required": true,
      "mask": false,
      "display": "always",
      "default": "1000"
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "1000",
      "description": "",
      "required": true,
      "mask": false,
      "display": "always",
      "default": "1000"
    }
  ],
  "devices": [],
  "labels": []
}