{
  "name": "Pelican-Wing",
  "repo": "ghcr.io/pelican-dev/wings:latest",
  "registry": null,
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "shell",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "cpu_set": null,
  "web_ui_url": null,
  "icon": "https://pelican.dev/img/logo.png",
  "category": ["Game Server"],
  "project": null,
  "support": null,
  "description": "https://pelican.dev/ Needs the config.yml from the Pelican Panel Container. (its shown once you add a node) the config.yml needs to be created where the **Pelican - Etc** is linked to.",
  "donate": null,
  "requires": null,
  "paths": [
    {
      "name": "Docker Sock",
      "host": "/var/run/docker.sock",
      "container": "/var/run/docker.sock",
      "description": "Do not change!"
    },
    {
      "name": "Pelican - Etc",
      "host": "/mnt/cache/appdata/pelican-wing/etc/pelican",
      "container": "/etc/pelican",
      "description": "For the config.yml (Check mount volume)"
    },
    {
      "name": "Pelican - Tmp",
      "host": "/tmp/pelican-wing/",
      "container": "/tmp/pelican/",
      "description": "Temp folder, Shouldn't need to change"
    },
    {
      "name": "Pelican Data",
      "host": "/mnt/cache/appdata/pelican-wing/data",
      "container": "/mnt/cache/appdata/pelican-wing/data",
      "description": "(Check mount volume)"
    }
  ],
"ports": [
    {
      "name": "WebHttp",
      "host": "8080",
      "container": "8080",
      "protocol": "TCP",
      "description": "Webserver port",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "SFTP",
      "host": "2022",
      "container": "2022",
      "protocol": "TCP",
      "description": "SFTP port for file transfering",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    }
  ],
  "variables": [
    {
      "name": "WINGS_UID",
      "key": "WINGS_UID",
      "value": "99",
      "description": "",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "WINGS_GID",
      "key": "WINGS_GID",
      "value": "100",
      "description": "",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "WINGS_USERNAME",
      "key": "WINGS_USERNAME",
      "value": "nobody",
      "description": "",
      "required": true,
      "mask": true,
      "display": "always",
      "default": null
    }
  ],
  "devices": [],
  "labels": []
}