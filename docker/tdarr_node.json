{
  "name": "tdarrnode-DEV",
  "repo": "ghcr.io/haveagitgat/tdarr_node",
  "registry": null,
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "shell",
  "privileged": false,
  "extra_parameters": "--gpus=all --restart=unless-stopped",
  "post_parameters": null,
  "cpu_set": null,
  "web_ui_url": null,
  "icon": "https://home.tdarr.io/static/media/logo3-min.246d6df44c7f16ddebaf.png",
  "category": ["Media"],
  "project": "https://github.com/haveagitgat/tdarr",
  "support": "https://github.com/haveagitgat/tdarr/issues",
  "description": "https://home.tdarr.io/ Tdarr is a conditional based transcoding application for automating media library transcode/remux management",
  "donate": null,
  "requires": "ghcr.io/haveagitgat/tdarr",
  "paths": [
    {
      "name": "Configs",
      "host": "/mnt/cache/appdata/tdarr/configs",
      "container": "/app/configs",
      "description": "Configs"
    },
    {
      "name": "Logs",
      "host": "/mnt/cache/appdata/tdarr/logs",
      "container": "/app/logs",
      "description": "Logs"
    },
    {
      "name": "Media Library",
      "host": "/mnt/cache/appdata/container",
      "container": "/mnt/media",
      "description": "Media Library volume"
    },
    {
      "name": "Transcode Cache",
      "host": "/mnt/cache/appdata/container",
      "container": "/temp",
      "description": "Transcode caching (use fast storage) "
    }

  ],
"ports": [
    {
      "name": "Node Port",
      "host": "8267",
      "container": "8267",
      "protocol": "TCP",
      "description": "Node Port",
      "required": true,
      "mask": false,
      "display": "always"
    }
  ],
  "variables": [
    {
      "name": "serverPort",
      "key": "serverPort",
      "value": "8266",
      "description": "",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "serverIP",
      "key": "serverIP",
      "value": "0.0.0.0",
      "description": "Required if using Tdarr Nodes across your local network",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "nodeIP",
      "key": "nodeIP",
      "value": "0.0.0.0",
      "description": "nodeIP. Required if using Tdarr Nodes across your local network",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "nodeID",
      "key": "nodeID",
      "value": "NodeName",
      "description": "Node ID Name",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "PUID",
      "key": "PUID",
      "value": "99",
      "description": "",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "100",
      "description": "",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    }
  ],
  "devices": [],
  "labels": []
}